{
  "name": "siege-scepter",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Siege & Scepter — browser-based asynchronous multiplayer strategy game",
  "scripts": {
    "dev": "pnpm --parallel --filter @siege/server --filter @siege/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @siege/server db:generate",
    "db:migrate": "pnpm --filter @siege/server db:migrate"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0"
  },
  "packageManager": "pnpm@10.28.0"
}
